PORT = 3000
NODE_ENV=development
MONGODB_URI=your_mongodb_connection_string

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# LLM Provider - choose one: "gemini" or "groq"
LLM_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# Groq (Llama 3)
GROQ_API_KEY=your_groq_api_key_here

# Embedding Model - "gemini" uses text-embedding-004, "groq" needs an external embedding API
EMBEDDING_PROVIDER = gemini

# MongoDB Vector Search Index Name (create in Atlas UI)
VECTOR_INDEX_NAME = vector_index

# RAG Config
CHUNK_SIZE = 1000
CHUNK_OVERLAP = 200
TOP_K_RESULTS = 5
SIMILARITY_THRESHOLD = 0.60

# File Upload
MAX_FILE_SIZE_MB = 50
UPLOAD_DIR = uploads

# Cache (seconds)
CACHE_TTL = 3600

# Rate Limiting
RATE_LIMIT_WINDOW_MS = 900000
RATE_LIMIT_MAX = 100

# SMTP Configuration (For Forgot Password OTP)
SMTP_HOST = smtp.gmail.com
SMTP_PORT = 587
SMTP_USER = your_email@example.com
SMTP_PASS = your_smtp_password_here
SMTP_SECURE = false
