# ══════════════════════════════════════════════════════════════
# OpsMind AI — Environment Configuration
# Copy to .env and fill in your values before running.
# ══════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Comma-separated allowed CORS origins (use * for development only)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── MongoDB Atlas ──────────────────────────────────────────────
# Get from: Atlas → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/opsmind?retryWrites=true&w=majority

# ── Authentication ─────────────────────────────────────────────
# Must be at least 32 characters. Use: openssl rand -base64 48
JWT_SECRET=replace_this_with_a_minimum_32_char_secret_string_here
JWT_EXPIRES_IN=7d

# ── LLM Provider ───────────────────────────────────────────────
# Choose one: "gemini" (default) or "groq"
LLM_PROVIDER=gemini

# Google Gemini (for both LLM and embeddings)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (Llama 3 70B) — only needed if LLM_PROVIDER=groq
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Embedding ──────────────────────────────────────────────────
EMBEDDING_PROVIDER=gemini
# Gemini text-embedding-004 produces 768-dimensional vectors

# ── MongoDB Atlas Vector Search ────────────────────────────────
# Must match the index name you create in Atlas UI
VECTOR_INDEX_NAME=vector_index
VECTOR_CANDIDATES=100        # ANN candidates to explore (higher = better recall, slower)

# ── RAG Pipeline Tuning ────────────────────────────────────────
# Chunking
CHUNK_SIZE=1000              # Characters per chunk (overlap-aware)
CHUNK_OVERLAP=200            # Overlap between consecutive chunks

# Retrieval
TOP_K_RESULTS=5              # Final chunks passed to LLM
KEYWORD_RESULTS_LIMIT=10     # Max keyword search candidates

# Hybrid search weights (must sum to 1.0)
HYBRID_VECTOR_WEIGHT=0.70    # Dense/semantic weight
HYBRID_KEYWORD_WEIGHT=0.30   # Sparse/lexical weight

# Anti-hallucination similarity threshold
# Chunks below this score are rejected → "I don't know" response
# Range: 0.0 (accept all) to 1.0 (reject all)
# Recommended: 0.65-0.75 for SOP content
SIMILARITY_THRESHOLD=0.70

# LLM Re-ranking
RERANK_ENABLED=true          # Use LLM to re-rank retrieved chunks
RERANK_TOP_N=10              # Candidates fed into reranker
RERANK_FINAL_N=5             # Final chunks after re-ranking

# ── LLM Generation Parameters ──────────────────────────────────
# Low temperature = more deterministic, less hallucination
LLM_TEMPERATURE=0.05
LLM_MAX_TOKENS=1500
LLM_TOP_P=0.85

# ── File Upload ────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50          # Max PDF size (MB)
UPLOAD_DIR=uploads           # Directory for uploaded PDFs
MAX_PDF_PAGES=500            # Safety cap for large PDFs

# ── Caching ────────────────────────────────────────────────────
CACHE_TTL=3600               # Query cache TTL in seconds (1 hour)

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=200           # Max requests per window per IP

# ══════════════════════════════════════════════════════════════
# MongoDB Atlas Vector Index Setup (REQUIRED)
#
# Create in Atlas UI → Search → Create Search Index → JSON Editor:
#
# Index Name: vector_index
# Collection: chunks
# Definition:
# {
#   "fields": [
#     {
#       "type": "vector",
#       "path": "embedding",
#       "numDimensions": 768,
#       "similarity": "cosine"
#     },
#     {
#       "type": "filter",
#       "path": "documentId"
#     },
#     {
#       "type": "filter",
#       "path": "tags"
#     }
#   ]
# }
#
# Also create a standard text index for keyword search:
# db.chunks.createIndex({ text: "text", documentName: "text" })
# ══════════════════════════════════════════════════════════════
