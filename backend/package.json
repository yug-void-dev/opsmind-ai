{
  "name": "opsmind-ai",
  "version": "2.0.0",
  "description": "OpsMind AI — Enterprise SOP Knowledge Agent with RAG (Hybrid Search + Gemini/Groq)",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start":       "node src/server.js",
    "dev":         "nodemon src/server.js",
    "test":        "jest --forceExit --detectOpenHandles",
    "test:watch":  "jest --watch",
    "test:ci":     "jest --forceExit --detectOpenHandles --ci --coverage",
    "setup":       "node scripts/create-vector-index.js",
    "seed":        "node scripts/seed-admin.js",
    "lint":        "eslint src/ --ext .js",
    "docker:up":   "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f opsmind-ai-backend",
    "docker:build":"docker compose build --no-cache"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bcryptjs":              "^2.4.3",
    "cors":                  "^2.8.5",
    "dotenv":                "^16.4.5",
    "express":               "^4.19.2",
    "express-rate-limit":    "^7.3.1",
    "groq-sdk":              "^0.5.0",
    "helmet":                "^7.1.0",
    "joi":                   "^17.13.1",
    "jsonwebtoken":          "^9.0.2",
    "mongoose":              "^8.5.1",
    "morgan":                "^1.10.0",
    "multer":                "^1.4.5-lts.1",
    "node-cache":            "^5.1.2",
    "pdf-parse":             "^1.1.1",
    "uuid":                  "^10.0.0",
    "winston":               "^3.13.1"
  },
  "devDependencies": {
    "jest":       "^29.7.0",
    "nodemon":    "^3.1.4",
    "supertest":  "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "forceExit":       true,
    "detectOpenHandles": true,
    "testTimeout":     30000,
    "collectCoverageFrom": ["src/**/*.js"],
    "coverageDirectory": "coverage"
  },
  "nodemonConfig": {
    "watch":  ["src/"],
    "ext":    "js,json",
    "ignore": ["node_modules/", "uploads/", "logs/"],
    "delay":  500
  },
  "keywords": ["rag", "llm", "sop", "enterprise", "knowledge-base", "gemini", "mongodb-atlas"],
  "license": "MIT"
}
